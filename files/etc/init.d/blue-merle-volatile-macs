#!/bin/sh /etc/rc.common
# blue-merle v2 — keep connected-client MAC database in RAM only.
#
# gl_clients (START=99) records client MACs to /etc/oui-tertf/client.db on flash.
# We mount a tmpfs over /etc/oui-tertf/ before gl_clients starts so that all
# writes go to RAM and the database never persists across reboots.
# The existing flash copy is shredded (or zero-wiped if shred unavailable).
#
# Must run before gl-tertf (START=60) and gl_clients (START=99).

START=9
STOP=99

DB_DIR="/etc/oui-tertf"
DB_FILE="${DB_DIR}/client.db"

_wipe() {
    local f="$1"
    [ -f "$f" ] || return 0
    if which shred >/dev/null 2>&1; then
        shred --force --remove "$f" 2>/dev/null
    else
        # Overwrite with zeros then remove.
        # Use large blocks for speed — coreutils-shred (IPK dep) replaces this.
        dd if=/dev/zero of="$f" bs=1M 2>/dev/null
        rm -f "$f"
    fi
}

start() {
    [ -d "$DB_DIR" ] || return 0

    # Already mounted — handles service restart without double-mount.
    if mount | grep -q "tmpfs on ${DB_DIR} "; then
        return 0
    fi

    # Wipe the flash copy so historical client MACs can't be recovered,
    # then mount tmpfs so all future writes go to RAM only.
    _wipe "$DB_FILE"
    mount -t tmpfs tmpfs "$DB_DIR"
}

stop() {
    # Wipe the RAM-backed db on shutdown so gl_clients sync has nothing to commit
    _wipe "$DB_FILE"
}
